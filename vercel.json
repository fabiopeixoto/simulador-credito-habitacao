{
  "version": 2,
  "builds": [
    { "src": "api/spreads.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/spreads", "dest": "/api/spreads.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
